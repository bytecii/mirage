{
  "name": "mirage-ts-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "mirage": "node packages/cli/dist/bin/mirage.js"
  },
  "pnpm": {
    "overrides": {
      "shell-quote@<1.9.0": ">=1.9.0 <2",
      "esbuild@<0.28.1": ">=0.28.1",
      "protobufjs@>=7.0.0 <7.6.5": ">=7.6.5 <8",
      "protobufjs@>=8.0.0 <8.6.6": ">=8.6.6 <9",
      "@anthropic-ai/sdk@>=0.79.0 <0.91.1": ">=0.91.1",
      "ip-address@<=10.1.0": ">=10.1.1",
      "uuid@<11.1.1": ">=11.1.1",
      "fast-xml-parser@<5.7.0": ">=5.7.2",
      "nodemailer@<9.0.1": ">=9.0.1",
      "form-data@<4.0.6": ">=4.0.6",
      "js-yaml@<3.15.0": ">=3.15.0 <4",
      "js-yaml@>=4.0.0 <4.3.0": ">=4.3.0 <5",
      "tar@<7.5.19": ">=7.5.19 <8",
      "vite@>=7.0.0 <7.3.5": ">=7.3.5 <8",
      "@opentelemetry/core@<2.8.0": ">=2.8.0",
      "@opentelemetry/propagator-jaeger@>=2.0.0 <2.9.0": ">=2.9.0 <3",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0 <8",
      "fast-uri@>=3.0.0 <3.1.4": ">=3.1.4 <4",
      "linkify-it@>=5.0.0 <5.0.2": ">=5.0.2 <6",
      "hono@>=4.0.0 <4.12.27": ">=4.12.27 <5",
      "@hono/node-server@<2.0.5": ">=2.0.5 <3",
      "body-parser@>=2.0.0 <2.3.0": ">=2.3.0 <3",
      "axios@>=1.0.0 <1.18.0": ">=1.18.0 <2",
      "brace-expansion@>=1.0.0 <1.1.16": ">=1.1.16 <2",
      "brace-expansion@>=5.0.0 <5.0.7": ">=5.0.7 <6"
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@struktoai/mirage-browser": "workspace:*",
    "@struktoai/mirage-core": "workspace:*",
    "@struktoai/mirage-node": "workspace:*",
    "@types/node": "^22.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.26.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  }
}
