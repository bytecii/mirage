{
  "cases": [
    {
      "id": "shift_non_numeric",
      "seq": 433,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix"
      ],
      "command": "shift x 2>&1; echo code=$?",
      "expect": {
        "exit": 0,
        "stdout": "shift: x: numeric argument required\ncode=1\n",
        "stderr": ""
      }
    },
    {
      "id": "shift_too_many",
      "seq": 434,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix"
      ],
      "command": "shift 1 2 2>&1; echo code=$?",
      "expect": {
        "exit": 0,
        "stdout": "shift: too many arguments\ncode=1\n",
        "stderr": ""
      }
    }
  ]
}
