{
  "cases": [
    {
      "id": "arith_cmd_true",
      "seq": 438,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
        "ssh",
        "nextcloud"
      ],
      "command": "(( 2 > 1 )); echo code=$?",
      "expect": {
        "exit": 0,
        "stdout": "code=0\n",
        "stderr": ""
      }
    },
    {
      "id": "arith_cmd_false",
      "seq": 439,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
        "ssh",
        "nextcloud"
      ],
      "command": "(( 0 )); echo code=$?",
      "expect": {
        "exit": 0,
        "stdout": "code=1\n",
        "stderr": ""
      }
    },
    {
      "id": "arith_incr",
      "seq": 440,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
        "ssh",
        "nextcloud"
      ],
      "command": "i=0; (( i++ )); echo code=$? i=$i; (( i++ )); echo code=$? i=$i; unset i",
      "expect": {
        "exit": 0,
        "stdout": "code=1 i=1\ncode=0 i=2\n",
        "stderr": ""
      }
    },
