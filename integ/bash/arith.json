    {
      "id": "arith_short_circuit",
      "seq": 446,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
        "ssh",
        "nextcloud"
