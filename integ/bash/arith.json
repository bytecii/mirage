      "expect": {
        "exit": 0,
        "stdout": "-3 -1 1024 16 8\n",
        "stderr": ""
      }
    },
    {
      "id": "arith_while",
      "seq": 443,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
        "ssh",
        "nextcloud"
      ],
      "command": "n=0; while (( n < 3 )); do (( n++ )); done; echo n=$n; unset n",
      "expect": {
        "exit": 0,
        "stdout": "n=3\n",
        "stderr": ""
      }
    },
