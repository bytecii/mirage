      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
        "ssh",
        "nextcloud"
      ],
      "command": "x=$(( y = 3, y + 2 )); echo $x $y; unset x y",
      "expect": {
        "exit": 0,
        "stdout": "5 3\n",
        "stderr": ""
      }
    },
    {
      "id": "arith_c_semantics",
      "seq": 442,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint",
