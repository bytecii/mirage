{
  "cases": [
    {
      "id": "glob_pattern_dup_word",
      "seq": 384,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "ssh",
        "nextcloud",
        "gdrive",
        "gdrive-folder",
        "box"
      ],
      "command": "mkdir -p /data/g8 && printf 'x *.txt y\\n' | tee /data/g8/l1.txt > /dev/null && printf 'plain\\n' | tee /data/g8/l2.txt > /dev/null && cd /data/g8 && grep -F '*.txt' *.txt && cd / && rm -r /data/g8",
      "expect": {
        "exit": 0,
        "stdout": "l1.txt:x *.txt y\n",
        "stderr": ""
      }
    }
  ]
}
