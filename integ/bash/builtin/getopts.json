  "cases": [
    {
      "id": "getopts_loop_basic",
      "seq": 502708,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "ssh",
        "nextcloud",
        "gdrive",
        "gdrive-folder",
        "box"
      ],
      "command": "OPTIND=1; set -- -a val -b; while getopts \"a:b\" opt; do case $opt in a) echo \"a=$OPTARG\";; b) echo \"b-set\";; esac; done",
      "expect": {
        "exit": 0,
        "stdout": "a=val\nb-set\n",
        "stderr": ""
      }
    },
