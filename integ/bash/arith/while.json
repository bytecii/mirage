{
  "cases": [
    {
      "id": "arith_while",
      "seq": 443,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "ssh",
        "nextcloud",
        "gdrive",
        "gdrive-folder",
        "box"
      ],
      "command": "n=0; while (( n < 3 )); do (( n++ )); done; echo n=$n; unset n",
      "expect": {
        "exit": 0,
        "stdout": "n=3\n",
        "stderr": ""
      }
    }
  ]
}
