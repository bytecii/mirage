{
  "resource": "nextcloud",
  "mount": "/nc",
  "watch_dir": "/nc/data",
  "seed": ["keep.txt"],
  "cases": [
    {
      "id": "create_file",
      "warm": ["ls /nc/data"],
      "mutate": {"op": "write", "path": "data/report.txt", "body": "alpha line\nbeta line\n"},
      "expect": {"kind": "create", "path": "/nc/data/report.txt"},
      "checks": [
        {"cmd": "cat /nc/data/report.txt", "contains": "alpha line"},
        {"cmd": "head -n 1 /nc/data/report.txt", "contains": "alpha line"},
        {"cmd": "ls /nc/data", "contains": "report.txt"},
        {"cmd": "grep -rl beta /nc/data", "contains": "report.txt"}
      ]
    },
    {
      "id": "update_etag_change",
      "warm": ["cat /nc/data/report.txt", "grep -rl alpha /nc/data"],
      "mutate": {"op": "write", "path": "data/report.txt", "body": "gamma line\ndelta line\n"},
      "expect": {"kind": "update", "path": "/nc/data/report.txt"},
      "checks": [
        {"cmd": "cat /nc/data/report.txt", "contains": "gamma line"},
        {"cmd": "cat /nc/data/report.txt", "absent": "alpha"},
        {"cmd": "grep -rl gamma /nc/data", "contains": "report.txt"},
        {"cmd": "grep -r alpha /nc/data", "absent": "report.txt"}
      ]
    },
    {
      "id": "create_nested",
      "warm": ["ls /nc/data"],
      "mutate": {"op": "write", "path": "data/sub/deep.txt", "body": "deep marker\n"},
      "expect": {"kind": "create", "path": "/nc/data/sub/deep.txt"},
      "checks": [
        {"cmd": "cat /nc/data/sub/deep.txt", "contains": "deep marker"},
        {"cmd": "grep -rl 'deep marker' /nc/data", "contains": "deep.txt"}
      ]
    },
    {
      "id": "delete_file",
      "warm": ["cat /nc/data/report.txt", "ls /nc/data"],
      "mutate": {"op": "delete", "path": "data/report.txt"},
      "expect": {"kind": "delete", "path": "/nc/data/report.txt"},
      "checks": [
        {"cmd": "ls /nc/data", "absent": "report.txt"},
        {"cmd": "grep -rl gamma /nc/data", "absent": "report.txt"}
      ]
    }
  ],
  "scopes": [
    {
      "id": "folder",
      "watch": ["/nc/data/sub"],
      "cases": [
        {
          "id": "inside_delivered",
          "mutate": {"op": "write", "path": "data/sub/in.txt", "body": "inside scope\n"},
          "expect": {"kind": "create", "path": "/nc/data/sub/in.txt"},
          "checks": [
            {"cmd": "cat /nc/data/sub/in.txt", "contains": "inside scope"}
          ]
        },
        {
          "id": "outside_skipped",
          "mutate": {"op": "write", "path": "data/out.txt", "body": "outside scope\n"},
          "expect": {"kind": "create", "path": "/nc/data/out.txt", "delivered": false}
        }
      ]
    },
    {
      "id": "pattern",
      "watch": ["/nc/data/*.txt"],
      "cases": [
        {
          "id": "txt_delivered",
          "mutate": {"op": "write", "path": "data/notes.txt", "body": "txt matches\n"},
          "expect": {"kind": "create", "path": "/nc/data/notes.txt"},
          "checks": [
            {"cmd": "cat /nc/data/notes.txt", "contains": "txt matches"}
          ]
        },
        {
          "id": "md_skipped",
          "mutate": {"op": "write", "path": "data/notes.md", "body": "md does not match\n"},
          "expect": {"kind": "create", "path": "/nc/data/notes.md", "delivered": false}
        },
        {
          "id": "nested_txt_skipped",
          "mutate": {"op": "write", "path": "data/sub/deep.txt", "body": "glob does not cross slash\n"},
          "expect": {"kind": "create", "path": "/nc/data/sub/deep.txt", "delivered": false}
        }
      ]
    },
    {
      "id": "shallow_glob",
      "watch": ["/nc/data/*"],
      "cases": [
        {
          "id": "top_level_delivered",
          "mutate": {"op": "write", "path": "data/top.txt", "body": "shallow scope\n"},
          "expect": {"kind": "create", "path": "/nc/data/top.txt"},
          "checks": [
            {"cmd": "cat /nc/data/top.txt", "contains": "shallow scope"}
          ]
        },
        {
          "id": "nested_skipped",
          "mutate": {"op": "write", "path": "data/sub/deep.txt", "body": "below shallow scope\n"},
          "expect": {"kind": "create", "path": "/nc/data/sub/deep.txt", "delivered": false}
        }
      ]
    },
    {
      "id": "dir_glob",
      "watch": ["/nc/data/*/"],
      "cases": [
        {
          "id": "inside_dir_delivered",
          "mutate": {"op": "write", "path": "data/sub/in.txt", "body": "inside a child dir\n"},
          "expect": {"kind": "create", "path": "/nc/data/sub/in.txt"},
          "checks": [
            {"cmd": "cat /nc/data/sub/in.txt", "contains": "inside a child dir"}
          ]
        },
        {
          "id": "top_level_skipped",
          "mutate": {"op": "write", "path": "data/top.txt", "body": "not inside a dir\n"},
          "expect": {"kind": "create", "path": "/nc/data/top.txt", "delivered": false}
        }
      ]
    },
    {
      "id": "mid_wildcard",
      "watch": ["/nc/data/*/reports/"],
      "cases": [
        {
          "id": "inside_reports_delivered",
          "mutate": {"op": "write", "path": "data/proj1/reports/spec.md", "body": "quarterly spec\n"},
          "expect": {"kind": "create", "path": "/nc/data/proj1/reports/spec.md"},
          "checks": [
            {"cmd": "cat /nc/data/proj1/reports/spec.md", "contains": "quarterly spec"}
          ]
        },
        {
          "id": "project_sibling_skipped",
          "mutate": {"op": "write", "path": "data/proj1/other.txt", "body": "outside reports\n"},
          "expect": {"kind": "create", "path": "/nc/data/proj1/other.txt", "delivered": false}
        }
      ]
    },
    {
      "id": "multi_roots",
      "watch": ["/nc/data/sub", "/nc/data/*.yaml"],
      "cases": [
        {
          "id": "literal_root_delivered",
          "mutate": {"op": "write", "path": "data/sub/in.txt", "body": "literal subtree\n"},
          "expect": {"kind": "create", "path": "/nc/data/sub/in.txt"},
          "checks": [
            {"cmd": "cat /nc/data/sub/in.txt", "contains": "literal subtree"}
          ]
        },
        {
          "id": "glob_root_delivered",
          "mutate": {"op": "write", "path": "data/app.yaml", "body": "yaml root\n"},
          "expect": {"kind": "create", "path": "/nc/data/app.yaml"},
          "checks": [
            {"cmd": "cat /nc/data/app.yaml", "contains": "yaml root"}
          ]
        },
        {
          "id": "neither_root_skipped",
          "mutate": {"op": "write", "path": "data/note.md", "body": "matches no root\n"},
          "expect": {"kind": "create", "path": "/nc/data/note.md", "delivered": false}
        }
      ]
    },
    {
      "id": "rename",
      "watch": ["/nc/data"],
      "cases": [
        {
          "id": "seed_orig",
          "mutate": {"op": "write", "path": "data/orig.txt", "body": "original content\n"},
          "expect": {"kind": "create", "path": "/nc/data/orig.txt"},
          "checks": [
            {"cmd": "cat /nc/data/orig.txt", "contains": "original content"}
          ]
        },
        {
          "id": "rename_as_move",
          "modes": ["push"],
          "warm": ["cat /nc/data/orig.txt", "ls /nc/data"],
          "mutate": {"op": "rename", "path": "data/orig.txt", "to": "data/renamed.txt"},
          "expect": {"kind": "move", "path": "/nc/data/renamed.txt", "previous": "/nc/data/orig.txt"},
          "checks": [
            {"cmd": "cat /nc/data/renamed.txt", "contains": "original content"},
            {"cmd": "ls /nc/data", "absent": "orig.txt"},
            {"cmd": "cat /nc/data/orig.txt", "absent": "original content"}
          ]
        },
        {
          "id": "rename_as_delete_create",
          "modes": ["pull"],
          "warm": ["cat /nc/data/orig.txt", "ls /nc/data"],
          "mutate": {"op": "rename", "path": "data/orig.txt", "to": "data/renamed.txt"},
          "expect": {"kind": "create", "path": "/nc/data/renamed.txt"},
          "checks": [
            {"cmd": "cat /nc/data/renamed.txt", "contains": "original content"},
            {"cmd": "ls /nc/data", "absent": "orig.txt"},
            {"cmd": "cat /nc/data/orig.txt", "absent": "original content"}
          ]
        }
      ]
    },
    {
      "id": "file",
      "watch": ["/nc/data/keep.txt"],
      "cases": [
        {
          "id": "update_delivered",
          "warm": ["cat /nc/data/keep.txt"],
          "mutate": {"op": "write", "path": "data/keep.txt", "body": "fresh keep\n"},
          "expect": {"kind": "update", "path": "/nc/data/keep.txt"},
          "checks": [
            {"cmd": "cat /nc/data/keep.txt", "contains": "fresh keep"},
            {"cmd": "cat /nc/data/keep.txt", "absent": "seed"}
          ]
        },
        {
          "id": "sibling_skipped",
          "mutate": {"op": "write", "path": "data/other.txt", "body": "sibling file\n"},
          "expect": {"kind": "create", "path": "/nc/data/other.txt", "delivered": false}
        },
        {
          "id": "delete_delivered",
          "warm": ["ls /nc/data"],
          "mutate": {"op": "delete", "path": "data/keep.txt"},
          "expect": {"kind": "delete", "path": "/nc/data/keep.txt"},
          "checks": [
            {"cmd": "ls /nc/data", "absent": "keep.txt"}
          ]
        }
      ]
    }
  ],
  "overflow": {
    "max_pending": 2,
    "paths": ["data/f1.txt", "data/f2.txt", "data/f3.txt", "data/f4.txt", "data/f5.txt"],
    "checks": [
      {"cmd": "ls /nc/data", "contains": "f5.txt"},
      {"cmd": "cat /nc/data/f3.txt", "contains": "burst"}
    ]
  }
}
