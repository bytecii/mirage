{
  "cases": [
    {"id": "slack_ls_root", "seq": 520000, "targets": ["slack"], "command": "ls /slack/", "expect": {"exit": 0, "stdout": "channels\ndms\nusers\n", "stderr": ""}},
    {"id": "slack_ls_channels", "seq": 520001, "targets": ["slack"], "command": "ls /slack/channels/", "expect": {"exit": 0, "stdout": "general__C1\nrandom__C2\n", "stderr": ""}},
    {"id": "slack_ls_dms", "seq": 520002, "targets": ["slack"], "command": "ls /slack/dms/", "expect": {"exit": 0, "stdout": "bob__D1\n", "stderr": ""}},
    {"id": "slack_ls_users", "seq": 520003, "targets": ["slack"], "command": "ls /slack/users/", "expect": {"exit": 0, "stdout": "alice__U1.json\nbob__U2.json\ncarol__U3.json\n", "stderr": ""}},
    {"id": "slack_ls_channel", "seq": 520004, "targets": ["slack"], "command": "ls /slack/channels/general__C1/", "expect": {"exit": 0, "stdout": "2026-01-01\n2026-01-02\n", "stderr": ""}},
    {"id": "slack_ls_day", "seq": 520005, "targets": ["slack"], "command": "ls /slack/channels/general__C1/2026-01-01/", "expect": {"exit": 0, "stdout": "chat.jsonl\nfiles\n", "stderr": ""}},
    {"id": "slack_ls_files", "seq": 520006, "targets": ["slack"], "command": "ls /slack/channels/general__C1/2026-01-01/files/", "expect": {"exit": 0, "stdout": "release_notes__F1.txt\n", "stderr": ""}},
    {"id": "slack_tree_channel", "seq": 520007, "targets": ["slack"], "command": "tree /slack/channels/general__C1/", "expect": {"exit": 0, "stdout": "├── 2026-01-01\n│   ├── chat.jsonl\n│   └── files\n│       └── release_notes__F1.txt\n└── 2026-01-02\n    ├── chat.jsonl\n    └── files\n", "stderr": ""}},
    {"id": "slack_find_chat", "seq": 520008, "targets": ["slack"], "command": "find /slack/channels/ -name chat.jsonl", "expect": {"exit": 0, "stdout": "/slack/channels/general__C1/2026-01-01/chat.jsonl\n/slack/channels/general__C1/2026-01-02/chat.jsonl\n/slack/channels/random__C2/2026-01-01/chat.jsonl\n", "stderr": ""}},
    {"id": "slack_cat_chat", "seq": 520009, "targets": ["slack"], "command": "cat /slack/channels/general__C1/2026-01-02/chat.jsonl", "expect": {"exit": 0, "stdout": "{\"type\":\"message\",\"user\":\"U1\",\"text\":\"rollback done, all clear\",\"ts\":\"1767346200.000300\"}\n", "stderr": ""}},
    {"id": "slack_cat_file", "seq": 520010, "targets": ["slack"], "command": "cat /slack/channels/general__C1/2026-01-01/files/release_notes__F1.txt", "expect": {"exit": 0, "stdout": "beta rollout checklist\n", "stderr": ""}},
    {"id": "slack_cat_user", "seq": 520011, "targets": ["slack"], "command": "cat /slack/users/alice__U1.json", "expect": {"exit": 0, "stdout": "{\"id\":\"U1\",\"name\":\"alice\",\"real_name\":\"Alice Anderson\",\"is_bot\":false,\"deleted\":false,\"profile\":{\"real_name\":\"Alice Anderson\",\"display_name\":\"alice\",\"email\":\"alice@example.com\"}}", "stderr": ""}},
    {"id": "slack_wc_chat", "seq": 520012, "targets": ["slack"], "command": "wc -l /slack/channels/general__C1/2026-01-01/chat.jsonl", "expect": {"exit": 0, "stdout": "2 /slack/channels/general__C1/2026-01-01/chat.jsonl\n", "stderr": ""}},
    {"id": "slack_grep_pushdown", "seq": 520013, "targets": ["slack"], "command": "grep -r beta /slack/channels/general__C1/", "expect": {"exit": 0, "stdout": "/slack/channels/general__C1/2026-01-01/chat.jsonl:[U1] let us deploy the beta build today\n/slack/channels/general__C1/2026-01-01/chat.jsonl:[U2] the beta looks good, shipping now\n/slack/channels/general__C1/2026-01-01/files/release_notes__F1.txt:[file] Release notes\n", "stderr": ""}},
    {"id": "slack_rg_pushdown", "seq": 520014, "targets": ["slack"], "command": "rg beta /slack/channels/general__C1/", "expect": {"exit": 0, "stdout": "/slack/channels/general__C1/2026-01-01/chat.jsonl:[U1] let us deploy the beta build today\n/slack/channels/general__C1/2026-01-01/chat.jsonl:[U2] the beta looks good, shipping now\n/slack/channels/general__C1/2026-01-01/files/release_notes__F1.txt:[file] Release notes\n", "stderr": ""}},
    {"id": "slack_grep_pushdown_empty", "seq": 520015, "targets": ["slack"], "command": "grep -r zzzznomatch /slack/channels/general__C1/", "expect": {"exit": 1, "stdout": "", "stderr": ""}},
    {"id": "slack_grep_users_walk", "seq": 520016, "targets": ["slack"], "command": "grep -rn Anderson /slack/users/", "expect": {"exit": 0, "stdout": "/slack/users/alice__U1.json:1:{\"id\":\"U1\",\"name\":\"alice\",\"real_name\":\"Alice Anderson\",\"is_bot\":false,\"deleted\":false,\"profile\":{\"real_name\":\"Alice Anderson\",\"display_name\":\"alice\",\"email\":\"alice@example.com\"}}\n", "stderr": ""}}
  ]
}
