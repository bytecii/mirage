{
  "cases": [
    {
      "id": "awk_first_col",
      "seq": 50,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "ssh",
        "nextcloud",
        "gdrive",
        "gdrive-folder",
        "box"
      ],
      "command": "cat /data/csv.csv | awk -F, '{print $1}'",
      "expect": {
        "exit": 0,
        "stdout": "name\nalice\nbob\n",
        "stderr": ""
      },
      "flags": [
        "F,"
      ]
    },
