{
  "cases": [
    {
      "id": "ometa_touch_create",
      "seq": 201005,
      "targets": [
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "box"
      ],
      "command": "touch -t 202601021530 /data/metao/new.txt",
      "check": {
        "stat": "/data/metao/new.txt",
        "fields": [
          "mode",
          "mtime"
        ]
      },
      "expect": {
        "exit": 0,
        "stdout": "mode=- mtime=2026-01-02T15:30:00\n",
        "stderr": ""
      }
    },
    {
      "id": "ometa_touch_nocreate",
      "seq": 201006,
      "targets": [
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "box"
      ],
      "command": "touch -c /data/metao/ghost.txt",
      "check": {
        "stat": "/data/metao/ghost.txt",
        "fields": [
          "mode"
        ]
      },
      "expect": {
        "exit": 0,
        "stdout": "absent\n",
        "stderr": ""
      }
    },
