      "id": "ometa_chmod_octal",
      "seq": 201001,
      "targets": [
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "box"
      ],
      "command": "chmod 601 /data/metao/f.txt",
      "check": {
        "stat": "/data/metao/f.txt",
        "fields": [
          "mode",
          "mtime"
        ]
      },
      "expect": {
        "exit": 0,
        "stdout": "mode=601 mtime=2026-01-02T15:30:00\n",
        "stderr": ""
      }
    },
    {
      "id": "ometa_chmod_symbolic",
      "seq": 201002,
      "targets": [
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "box"
      ],
      "command": "chmod u+x,go-r /data/metao/f.txt",
      "check": {
