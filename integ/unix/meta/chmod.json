        "dropbox-root",
        "onedrive",
        "sharepoint",
        "sharepoint-prefix",
        "ssh",
        "nextcloud",
        "gdrive",
        "gdrive-folder",
        "box"
      ],
      "command": "chmod 601 /data/metad/f.txt && ls -l /data/metad",
      "expect": {
