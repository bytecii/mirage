      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "databricks",
        "gridfs",
        "s3-prefix",
        "databricks-prefix",
        "gridfs-prefix",
        "hf",
        "hf-prefix",
        "dropbox",
        "dropbox-root",
        "onedrive",
        "sharepoint",
