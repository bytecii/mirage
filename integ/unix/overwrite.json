        "exit": 0,
        "stdout": "f.old\nf.txt\n",
        "stderr": ""
      }
    },
    {
      "id": "ow_cleanup",
      "seq": 203005,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix",
        "onedrive",
        "sharepoint"
      ],
      "command": "rm -r /data/ow && echo cleaned",
