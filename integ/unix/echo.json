      "seq": 430,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix"
      ],
      "command": "echo hi -n",
      "expect": {
        "exit": 0,
        "stdout": "hi -n\n",
        "stderr": ""
      }
    },
    {
      "id": "echo_cluster",
      "seq": 431,
      "targets": [
        "ram",
        "disk",
        "redis",
        "opfs",
        "s3",
        "s3-prefix"
      ],
      "command": "echo -ne 'ab\\tcd'; echo",
      "expect": {
        "exit": 0,
        "stdout": "ab\tcd\n",
        "stderr": ""
      }
    },
